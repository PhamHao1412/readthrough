# ==============================================
# Readthrough Backend — Environment Variables
# ==============================================

# -----------------
# Application Configuration
# -----------------
PORT=8080
ENV=dev
APP_NAME=readthrough-be
LOG_LEVEL=debug

# -----------------
# Database (PostgreSQL)
# -----------------
# Format: postgres://<user>:<password>@<host>:<port>/<database>?sslmode=<mode>&search_path=<schema>
DB_URL=postgres://postgres:postgres@localhost:5432/playground?sslmode=disable
DB_SCHEMA_NAME=public

# -----------------
# JWT Authentication
# -----------------
# Access token secret — use a random string of at least 32 characters
JWT_SECRET=your_secret_key_at_least_32_characters

# -----------------
# File Upload Directory
# -----------------
# Directory to store uploaded books (PDF/EPUB) locally if R2 is not configured
UPLOAD_DIR=uploads

# -----------------
# CORS Configuration (Optional)
# -----------------
# Origins allowed to connect to the API (separated by commas)
ALLOWED_ORIGINS=http://localhost:5173

# -----------------
# Cloudflare R2 Storage (Optional)
# -----------------
# Configured for cloud storage of books; if blank, backend falls back to local UPLOAD_DIR
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ACCOUNT_ID=
R2_BUCKET_NAME=

# -----------------
# OpenAI Integration
# -----------------
# OpenAI API key and model selection for translation and contextual explanations
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
