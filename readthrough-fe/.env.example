# ==============================================
# Readthrough Frontend — Environment Variables
# ==============================================

# -----------------
# API Base URL Configuration
# -----------------
# Base URL of the backend API server.
# Leave blank during local development so Vite dev proxy handles routing (/api -> http://localhost:8080)
VITE_API_BASE_URL=

# -----------------
# Application Metadata
# -----------------
VITE_APP_NAME=ReadThrough
VITE_APP_VERSION=1.0.0
